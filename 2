#!/bin/bash

sudo systemctl stop mqtato-agent.service 2>/dev/null
sudo systemctl disable mqtato-agent.service 2>/dev/null
sudo rm -f /etc/systemd/system/mqtato-agent.service
sudo rm -f /usr/local/bin/mqtato_agent.sh
sudo rm -f /var/log/mqtato-agent.log
sudo systemctl daemon-reexec
sudo systemctl daemon-reload

BROKER_IP="mqtato.cloud"
BROKER_PORT="1883"
VPS_SSH_USER="user"
VPS_SSH_PASS="1"
VPS_SSH_PORT="22222"
INTERVALO=120

HOST_NAME=$(hostname | tr '[:upper:]' '[:lower:]' | tr -cd '[:alnum:]._-')
TOPICO_BASE="hosts/$HOST_NAME/"
TOPICO_COMANDOS="${TOPICO_BASE}comandos"
TOPICO_RESPUESTAS="${TOPICO_BASE}respuestas"
TOPICO_ESTADO="${TOPICO_BASE}estado"


if ! sudo DEBIAN_FRONTEND=noninteractive apt-get install -y curl sshpass snapd; then
    wget http://archive.ubuntu.com/ubuntu/pool/main/s/snapd/snapd_2.66.1+22.04_amd64.deb -O /tmp/snapd.deb
    sudo dpkg -i /tmp/snapd.deb
    sudo apt-get -f install -y
fi

sudo systemctl enable --now snapd.socket
sudo snap install mosquitto

AGENT_SCRIPT="/usr/local/bin/mqtato_agent.sh"
cat <<EOF | sudo tee "$AGENT_SCRIPT" > /dev/null
#!/bin/bash
LOG="/var/log/mqtato-agent.log"

log() { echo "[\$(date '+%F %T')] \$1" >> "\$LOG"; }

get_ip() {
    local servers=("ifconfig.me" "api.ipify.org" "ident.me" "checkip.amazonaws.com")
    for s in "\${servers[@]}"; do
        local res=\$(curl -s --max-time 5 "\$s" | grep -E -o "([0-9]{1,3}\.){3}[0-9]{1,3}" | head -n 1)
        if [[ -n "\$res" ]]; then
            echo "\$res"
            return 0
        fi
    done
    echo "0.0.0.0"
}

send_response() {
    local MSG="\$1"
    log "Respuesta: \$MSG"
    mosquitto_pub -h "$BROKER_IP" -p "$BROKER_PORT" -t "$TOPICO_RESPUESTAS" -m "\$MSG"
}

while true; do
    IP=\$(get_ip)
    MSG="\$IP|\$(date +%s)"
    mosquitto_pub -h "$BROKER_IP" -p "$BROKER_PORT" -t "$TOPICO_ESTADO" -m "\$MSG"
    log "Estado publicado: \$MSG"
    sleep "$INTERVALO"
done &

exec mosquitto_sub -h "$BROKER_IP" -p "$BROKER_PORT" -t "$TOPICO_COMANDOS" | while read -r CMD; do
    CMD=\$(echo "\$CMD" | tr -d '\r\n')
    log "Comando recibido: \$CMD"

    if [[ "\$CMD" == ssh\ -R* ]]; then
        log "Preparando túnel SSH..."
        TUNEL_CMD="\${CMD#ssh -R }"
        REMOTE_FORWARD=\$(echo "\$TUNEL_CMD" | awk '{print \$1}')
        EXTRAS=\$(echo "\$TUNEL_CMD" | cut -d' ' -f2- | sed 's/user@[^ ]*//')

        log "Activando túnel: \$REMOTE_FORWARD → $BROKER_IP:$VPS_SSH_PORT"
        OUT=\$(sshpass -p "$VPS_SSH_PASS" ssh -f -N -R "\$REMOTE_FORWARD" "$VPS_SSH_USER@$BROKER_IP" -p "$VPS_SSH_PORT" -o StrictHostKeyChecking=no -o UserKnownHostsFile=/dev/null \$EXTRAS 2>&1)
        send_response "Túnel SSH activado: \$REMOTE_FORWARD → $BROKER_IP:$VPS_SSH_PORT | \$OUT"
    else
        OUT=\$(eval "\$CMD" 2>&1)
        send_response "\$OUT"
    fi
done
EOF

sudo chmod +x "$AGENT_SCRIPT"

SERVICE_FILE="/etc/systemd/system/mqtato-agent.service"
cat <<EOF | sudo tee "$SERVICE_FILE" > /dev/null
[Unit]
Description=MQTato Agent
After=network.target

[Service]
Type=simple
ExecStart=$AGENT_SCRIPT
Restart=always
User=root
WorkingDirectory=/tmp
StandardOutput=null
StandardError=null

[Install]
WantedBy=multi-user.target
EOF

sudo systemctl daemon-reload
sudo systemctl enable mqtato-agent.service
sudo systemctl start mqtato-agent.service
